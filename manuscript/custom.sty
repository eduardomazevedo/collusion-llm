\ProvidesPackage{custom}

% Character encoding
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}

% Bibliography with biber backend
\RequirePackage[
  backend=biber,
  style=authoryear,
  sorting=nyt,
  maxcitenames=2,
  mincitenames=1,
  maxbibnames=99,
  minbibnames=99,
  uniquename=false,
  uniquelist=false,
  useprefix=true
]{biblatex}
% Add bibliography resource file
\addbibresource{bibliography.bib}

% Drop "p."/"pp." prefixes in page and page-range fields
\DeclareFieldFormat{pages}{#1}
\DeclareFieldFormat{page}{#1}

% Remove "In:" before journal or book titles in references
\renewbibmacro{in:}{}

% Use "Name, eds." instead of "Ed. by Name"
\renewbibmacro*{byeditor+others}{%
  \ifnameundef{editor}
    {}
    {\printnames[byeditor]{editor}%
     \setunit{\addcomma\space}%
     \ifboolexpr{
       test {\ifnumgreater{\value{editor}}{1}}
       or
       test {\ifandothers{editor}}
     }
       {\printtext{\bibstring{editors}}}
       {\printtext{\bibstring{editor}}}%
     \clearname{editor}%
     \newunit}%
  \usebibmacro{byeditorx}%
  \usebibmacro{bytranslator+others}}

% Add comma before suffix in given-family order (e.g., "Joseph E. Harrington, Jr.")
\renewbibmacro*{name:given-family}[4]{%
  \usebibmacro{name:delim}{#2#3#1}%
  \usebibmacro{name:hook}{#2#3#1}%
  \mkbibcompletenamegivenfamily{%
    \ifdefvoid{#2}
      {}
      {\mkbibnamegiven{#2}\isdot\bibnamedelimd}%
    \ifdefvoid{#3}
      {}
      {\mkbibnameprefix{#3}\isdot
       \ifprefchar
         {}
         {\ifuseprefix{\bibnamedelimc}{\bibnamedelimd}}}%
    \mkbibnamefamily{#1}\isdot
    \ifdefvoid{#4}{}{\addcomma\space\mkbibnamesuffix{#4}\isdot}}}

% Put suffix after given name in family-given order (e.g., "Harrington, Joseph E., Jr.")
\renewbibmacro*{name:family-given}[4]{%
  \ifuseprefix
    {\usebibmacro{name:delim}{#3#1}%
     \usebibmacro{name:hook}{#3#1}%
     \mkbibcompletenamefamilygiven{%
       \ifdefvoid{#3}
         {}
         {\ifcapital
            {\mkbibnameprefix{\MakeCapital{#3}}\isdot}
            {\mkbibnameprefix{#3}\isdot}%
          \ifprefchar{}{\bibnamedelimc}}%
       \mkbibnamefamily{#1}\isdot
       \ifdefvoid{#2}
         {}
         {\revsdnamepunct\bibnamedelimd\mkbibnamegiven{#2}\isdot}%
       \ifdefvoid{#4}
         {}
         {\ifboolexpe{test {\ifdefvoid{#2}}}{\revsdnamepunct}{\addcomma\space}%
          \mkbibnamesuffix{#4}\isdot}}}
    {\usebibmacro{name:delim}{#1}%
     \usebibmacro{name:hook}{#1}%
     \mkbibcompletenamefamilygiven{%
       \mkbibnamefamily{#1}\isdot
       \ifboolexpe{%
         test {\ifdefvoid{#2}}
         and
         test {\ifdefvoid{#3}}}
         {}
         {\revsdnamepunct}%
       \ifdefvoid{#2}
         {}
         {\bibnamedelimd\mkbibnamegiven{#2}\isdot}%
       \ifdefvoid{#4}
         {}
         {\ifboolexpe{test {\ifdefvoid{#2}}}{\revsdnamepunct}{\addcomma\space}%
          \mkbibnamesuffix{#4}\isdot}%
       \ifdefvoid{#3}
         {}
         {\bibnamedelimd\mkbibnameprefix{#3}\isdot}}}}

% Fonts
\RequirePackage{mathpazo}

% Colors
\RequirePackage{xcolor}
\definecolor{ghibli_palette_red}{RGB}{255, 92, 92}
\definecolor{ghibli_palette_gold}{RGB}{255, 215, 0}
\definecolor{ghibli_palette_deep_teal}{RGB}{59, 105, 120}
\definecolor{ghibli_palette_cream}{RGB}{249, 245, 227}
\definecolor{ghibli_palette_light_gray}{RGB}{218, 218, 218}
\definecolor{ghibli_palette_gray}{RGB}{108, 122, 142}
\definecolor{ghibli_palette_blue}{RGB}{143, 177, 233}
\definecolor{ghibli_palette_green}{RGB}{166, 215, 132}
\definecolor{ghibli_palette_muted_green}{RGB}{132, 165, 157}
\definecolor{ghibli_palette_warm_red}{RGB}{242, 132, 130}

% Essential packages
\RequirePackage{graphicx}
\RequirePackage{amsmath}
\RequirePackage{amsthm}
\RequirePackage{amssymb}
\RequirePackage{fullpage}
\RequirePackage[hidelinks]{hyperref}
\RequirePackage{subcaption}
\IfFileExists{placeins.sty}{\RequirePackage{placeins}}{\providecommand{\FloatBarrier}{}}

% Float placement parameters - aggressively prevent float-only pages
% Make it very hard to create a float-only page (require 90% of page to be floats)
\renewcommand{\floatpagefraction}{0.9}
% Allow floats to take up most of the page with text
\renewcommand{\topfraction}{0.95}
\renewcommand{\bottomfraction}{0.95}
\renewcommand{\textfraction}{0.05}  % Allow very little text on float pages
% Allow more floats per page
\setcounter{topnumber}{4}
\setcounter{bottomnumber}{4}
\setcounter{totalnumber}{6}
% Make LaTeX try harder to place floats inline
\setlength{\floatsep}{12pt plus 2pt minus 2pt}
\setlength{\textfloatsep}{20pt plus 2pt minus 4pt}
\setlength{\intextsep}{12pt plus 2pt minus 2pt}

% Table packages
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{longtable}
\RequirePackage{threeparttable}

% TikZ packages for flowcharts
\RequirePackage{tikz}
\usetikzlibrary{positioning,arrows.meta,fit,backgrounds}
\RequirePackage{adjustbox}

% Apply the color links
\hypersetup{
    colorlinks=true,       % Enable colored links
    linkcolor=ghibli_palette_red,      % Color for internal links (e.g., equations, sections)
    citecolor=ghibli_palette_deep_teal,      % Color for citations
    urlcolor=ghibli_palette_deep_teal        % Color for URLs
}

% Theorem environments setup
\theoremstyle{plain}
\newtheorem{proposition}{Proposition}
\newtheorem{assumption}{Assumption}
\newtheorem{theorem}{Theorem}
\newtheorem{lemma}{Lemma}
\newtheorem{corollary}{Corollary}

% Appendix counter management
\RequirePackage{chngcntr}
\RequirePackage{apptools}
\AtAppendix{
    \counterwithin{proposition}{section}
    \counterwithin{assumption}{section}
    \counterwithin{theorem}{section}
    \counterwithin{lemma}{section}
    \counterwithin{corollary}{section}
    \counterwithin{equation}{section}
}

% Mathematical notation
\newcommand{\E}{\mathbb{E}}
\newcommand{\Var}{\mathrm{Var}}
\newcommand{\Cov}{\mathrm{Cov}}
\newcommand{\supp}{\mathrm{supp}}
\newcommand{\ubar}[1]{\text{\b{$#1$}}}

